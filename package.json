{
  "name": "vue-localeflow",
  "version": "0.1.2",
  "description": "A lightweight, type-safe Vue 3 internationalization (i18n) solution with reactive language switching and localStorage support",
  "type": "module",
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "skills",
    "README.md",
    "README.en.md"
  ],
  "keywords": [
    "vue",
    "vue3",
    "i18n",
    "internationalization",
    "locale",
    "language",
    "typescript",
    "reactive"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/lblblong/vue-localeflow.git"
  },
  "homepage": "https://github.com/lblblong/vue-localeflow#readme",
  "bugs": {
    "url": "https://github.com/lblblong/vue-localeflow/issues"
  },
  "author": "lblblong <1162275271@qq.com>",
  "license": "MIT",
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "prepublishOnly": "tsdown"
  },
  "peerDependencies": {
    "vue": "^3.5.21"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsdown": "^0.21.7",
    "typescript": "~5.8.3",
    "vue": "^3.5.21"
  }
}
